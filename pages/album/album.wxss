.page { display: flex; flex-direction: column; height: 100vh; background: #09090b; }

.toolbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 28rpx; border-bottom: 2rpx solid #27272a;
}
.count-text { color: #a1a1aa; font-size: 26rpx; }
.toolbar-btns { display: flex; gap: 16rpx; }
.tb-btn { font-size: 24rpx; line-height: 56rpx; padding: 0 28rpx; margin: 0; }

.empty {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 20rpx; padding: 0 60rpx;
}
.empty-title { color: #a1a1aa; font-size: 32rpx; }
.empty-sub { color: #71717a; font-size: 24rpx; text-align: center; }

.grid-scroll { flex: 1; }
.grid {
  display: flex; flex-wrap: wrap; gap: 8rpx; padding: 12rpx;
}
.cell {
  position: relative;
  width: calc((100vw - 60rpx) / 3);
  height: calc((100vw - 60rpx) / 3 * 4 / 3);
  border-radius: 12rpx; overflow: hidden; background: #27272a;
}
.cell-img { width: 100%; height: 100%; }

.ov {
  position: absolute; left: 0; right: 0;
  display: flex; flex-wrap: wrap; gap: 8rpx; padding: 10rpx;
  pointer-events: none;
}
.ov-t { top: 0; }
.ov-b { bottom: 0; }
.ov-l { justify-content: flex-start; }
.ov-c { justify-content: center; }
.ov-r { justify-content: flex-end; }
.ov-chip {
  color: #fff; font-weight: 600;
  padding: 4rpx 14rpx; border-radius: 999rpx;
  white-space: nowrap;
}

.check {
  position: absolute; top: 10rpx; right: 10rpx;
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: rgba(0,0,0,0.4); border: 2rpx solid rgba(255,255,255,0.7);
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 26rpx;
}
.check-on { background: #f97316; border-color: #f97316; }

.bottom-bar {
  display: flex; gap: 20rpx;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #27272a;
}
.bar-btn { flex: 1; font-size: 28rpx; margin: 0; }
.btn-danger { background: #3f1d1d; color: #ef4444; border-radius: 999rpx; }
.btn-danger::after { border: none; }

.offscreen {
  position: fixed; left: -9999px; top: -9999px;
  width: 300px; height: 300px;
}
